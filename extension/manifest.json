{
  "manifest_version": 3,
  "name": "GleanMark",
  "version": "0.1.0",
  "description": "Save and search bookmarks with semantic search",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  }
}
